PORT=3000
NODE_ENV=development

# PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost:5432/static_ads_generator
# Set to "true" when connecting to a managed Postgres that requires SSL
DATABASE_SSL=false

# Gemini (Google AI) — used for prompt composition, reverse engineering, etc.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# FAL — used for image generation
FAL_KEY=
FAL_MODEL=fal-ai/flux/dev
